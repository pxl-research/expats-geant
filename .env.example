                            # Expats Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM API Configuration (Choose one or both)
# ============================================

# OpenRouter (recommended for production)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OR OpenAI (alternative)
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Default LLM model (shared fallback for all services)
# See available models at: https://openrouter.ai/models
DEFAULT_LLM_MODEL=anthropic/claude-haiku-4.5

# Per-service model overrides (docker-compose maps these to LLM_MODEL inside each container)
CUE_LLM_MODEL=anthropic/claude-sonnet-4.6
SHAPE_LLM_MODEL=google/gemini-3-flash-preview

# Extended thinking budget in tokens (leave unset to disable).
# 10000 = "medium" for claude-sonnet-4-6. Only works with Anthropic Claude 3.5+/4.x models.
# THINKING_BUDGET_TOKENS=10000

# LLM Base URL (optional, uses default if not set)
# LLM_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# Authentication & Security
# ============================================

# Environment (development, staging, production)
# In production: placeholder secrets block startup, API docs (/docs, /redoc) are disabled
ENVIRONMENT=development

# Enable HSTS header (set to true when behind a TLS-terminating reverse proxy)
# ENABLE_HSTS=true

# JWT secret (REQUIRED - change in production!)
JWT_SECRET=change-this-to-a-secure-random-secret-in-production

# Shared secret for server-to-server /auth/token endpoint
# API_SECRET=change-this-to-a-secure-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Session & Storage Configuration
# ============================================

# Session TTL (hours)
SESSION_TTL_HOURS=24

# Background cleanup job interval (minutes) — how often expired sessions are swept
CLEANUP_JOB_INTERVAL_MINUTES=60

# Audit report retention (days)
AUDIT_RETENTION_DAYS=365

# File upload limits
MAX_FILE_SIZE_MB=50

# Maximum semantic distance for a retrieved chunk to be included as a citation (lower = stricter)
CUE_MAX_CITATION_DISTANCE=1.5

# Data paths (for Docker)
SESSIONS_BASE_PATH=/app/data/sessions
CHROMA_BASE_PATH=/app/data/chroma

# ============================================
# Server Configuration
# ============================================

# API server settings
PORT=8001
HOST=0.0.0.0
LOG_LEVEL=INFO

# ============================================
# OIDC Configuration (Keycloak or any OIDC provider)
# ============================================
# Uncomment and fill in these values to enable OIDC login via /auth/login and /auth/callback.
# Leave commented out to use /dev/token (development) or a pre-issued JWT (production).

# OIDC_ISSUER_URL=http://localhost:8080/realms/expats
# OIDC_CLIENT_ID=cue-api
# OIDC_CLIENT_SECRET=change-me

# Cue UI flow (8002 → 8001): where Keycloak redirects after login (must be browser-accessible)
# OIDC_REDIRECT_URI=http://localhost:8002/auth/callback

# Shape UI flow (8004 → 8003): where Keycloak redirects after login (must be browser-accessible)
# SHAPE_OIDC_REDIRECT_URI=http://localhost:8004/auth/callback

# ============================================
# Deployment Configuration (set these for non-localhost deployments)
# ============================================
# Replace with the actual IP or hostname where users access the services.
# These must be browser-accessible URLs (not Docker-internal hostnames).

# Public URL of cue-api as seen by the user's browser (used by cue_ui to redirect for login)
# CUE_PUBLIC_URL=http://localhost:8001

# Public URL of shape-api as seen by the user's browser (used by shape_ui to redirect for login)
# SHAPE_PUBLIC_URL=http://localhost:8003

# Example for a deployed instance at 10.0.0.1:
# CUE_PUBLIC_URL=http://10.0.0.1:8001
# OIDC_REDIRECT_URI=http://10.0.0.1:8002/auth/callback
# SHAPE_PUBLIC_URL=http://10.0.0.1:8003
# SHAPE_OIDC_REDIRECT_URI=http://10.0.0.1:8004/auth/callback
# KEYCLOAK_PUBLIC_URL=http://10.0.0.1:8080
#
# IMPORTANT: After setting these, register the deployed redirect URIs in Keycloak.
#   The admin UI may be unreachable without KC_HOSTNAME_ADMIN set, so use kcadm.sh inside the container.
#   See docs/DEPLOYMENT.md (Non-Localhost Deployment) for the full kcadm.sh walkthrough.
#   You must update: redirectUris, webOrigins, and post.logout.redirect.uris.
# The realm-export.json is only used on first import and does not support variable substitution.

# ============================================
# Keycloak Admin (only needed when running bundled Keycloak via docker-compose)
# ============================================
# KEYCLOAK_ADMIN_PASSWORD=admin

# Hostname used for the Keycloak admin console (set to your server IP/hostname for remote access).
# Without this, the admin UI redirects to http://keycloak:8080 which is only reachable inside Docker.
# KC_HOSTNAME_ADMIN=http://localhost:8080

# ============================================
# Future Use
# ============================================

# Database Configuration (not yet implemented)
# DATABASE_URL=postgresql://user:password@localhost:5432/expats
