                            # Expat-GÉANT Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM API Configuration (Choose one or both)
# ============================================

# OpenRouter (recommended for production)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OR OpenAI (alternative)
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Default LLM model (optional)
# Examples: anthropic/claude-haiku-4.5, openai/gpt-4, mistral/mixtral-8x7b
# See available models at: https://openrouter.ai/models
LLM_MODEL=anthropic/claude-haiku-4.5

# LLM Base URL (optional, uses default if not set)
# LLM_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# Authentication & Security
# ============================================

# JWT secret (REQUIRED - change in production!)
JWT_SECRET=change-this-to-a-secure-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Session & Storage Configuration
# ============================================

# Session TTL (hours)
SESSION_TTL_HOURS=24

# Audit report retention (days)
AUDIT_RETENTION_DAYS=365

# File upload limits
MAX_FILE_SIZE_MB=50

# Data paths (for Docker)
SESSIONS_BASE_PATH=/app/data/sessions
CHROMA_BASE_PATH=/app/data/chroma

# ============================================
# Server Configuration
# ============================================

# API server settings
PORT=8001
HOST=0.0.0.0
LOG_LEVEL=INFO

# ============================================
# Future Use
# ============================================

# Database Configuration (not yet implemented)
# DATABASE_URL=postgresql://user:password@localhost:5432/expat_geant
