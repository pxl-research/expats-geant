# Expats Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM API Configuration
# ============================================

# OpenRouter (recommended)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI-compatible alternative (uncomment to use instead of OpenRouter)
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1

# Default LLM model — shared fallback when a per-service model is not set
# See available models at: https://openrouter.ai/models
DEFAULT_LLM_MODEL=anthropic/claude-haiku-4.5

# Per-service model overrides (fall back to DEFAULT_LLM_MODEL when unset)
CUE_LLM_MODEL=anthropic/claude-sonnet-4.6
SHAPE_LLM_MODEL=google/gemini-3-flash-preview

# Extended thinking budget in tokens (leave unset to disable)
# 10000 = "medium" for claude-sonnet-4-6. Only works with Anthropic Claude 3.5+/4.x models.
# THINKING_BUDGET_TOKENS=10000

# ============================================
# Cue RAG Pipeline
# ============================================

# Maximum semantic distance for a retrieved chunk to be included as a citation (lower = stricter)
CUE_MAX_CITATION_DISTANCE=1.8

# Query rewriting: rephrase survey questions into concise search queries before vector search
CUE_QUERY_REWRITE=true
# Maximum number of questions rewritten in a single LLM call
CUE_REWRITE_BATCH_SIZE=20
# Dedicated model for query rewriting (falls back to DEFAULT_LLM_MODEL when unset)
# CUE_REWRITE_MODEL=google/gemini-3-flash-preview

# ============================================
# Authentication & Security
# ============================================

# Environment (development, staging, production)
# In production: placeholder secrets block startup, API docs (/docs, /redoc) are disabled
ENVIRONMENT=development

# Enable HSTS header (set to true when behind a TLS-terminating reverse proxy)
# ENABLE_HSTS=true

# JWT secret (REQUIRED — change in production!)
JWT_SECRET=change-this-to-a-secure-random-secret-in-production

# Shared secret for server-to-server /auth/token endpoint
# API_SECRET=change-this-to-a-secure-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Session & Storage
# ============================================

# Session TTL (hours)
SESSION_TTL_HOURS=24

# Background cleanup job interval (minutes) — how often expired sessions are swept
CLEANUP_JOB_INTERVAL_MINUTES=60

# Audit report retention (days)
AUDIT_RETENTION_DAYS=365

# File upload limits
MAX_FILE_SIZE_MB=50

# ============================================
# Server & Deployment
# ============================================

PORT=8001
HOST=0.0.0.0
LOG_LEVEL=INFO

# Data paths (Docker-internal, no need to change for standard deployments)
SESSIONS_BASE_PATH=/app/data/sessions
CHROMA_BASE_PATH=/app/data/chroma

# ============================================
# OIDC Configuration (Keycloak or any OIDC provider)
# ============================================
# Uncomment and fill in these values to enable OIDC login via /auth/login and /auth/callback.
# Leave commented out to use /dev/token (development) or a pre-issued JWT (production).

# OIDC_ISSUER_URL=http://localhost:8080/realms/expats
# OIDC_CLIENT_ID=cue-api
# OIDC_CLIENT_SECRET=change-me

# Cue UI flow (8002 → 8001): where Keycloak redirects after login (must be browser-accessible)
# OIDC_REDIRECT_URI=http://localhost:8002/auth/callback

# Shape UI flow (8004 → 8003): where Keycloak redirects after login (must be browser-accessible)
# SHAPE_OIDC_REDIRECT_URI=http://localhost:8004/auth/callback

# ============================================
# Non-Localhost Deployment
# ============================================
# Set PUBLIC_HOST to your server's IP or hostname. All public URLs (Cue, Shape,
# Keycloak) are automatically derived from it. No other URL variables needed.
# PUBLIC_HOST=10.0.0.1

# After first startup, register redirect URIs in Keycloak:
#   scripts/setup_keycloak.sh <admin-password>

# ============================================
# Keycloak Admin (only needed when running bundled Keycloak via docker-compose)
# ============================================
# KEYCLOAK_ADMIN_PASSWORD=change-me-asap

# ============================================
# Multi-Tenant Credential Routing (optional)
# ============================================
# Enable per-tenant LLM API key routing. When not configured, the system
# operates in single-tenant mode using the global OPENROUTER_API_KEY.

# Path to the tenant registry JSON file (mounted volume or .secrets/ directory)
# TENANT_REGISTRY_PATH=.secrets/tenants.json

# Fernet encryption key for decrypting tenant API keys at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TENANT_ENCRYPTION_KEY=

# ============================================
# Future Use
# ============================================

# Database Configuration (not yet implemented)
# DATABASE_URL=postgresql://user:password@localhost:5432/expats
