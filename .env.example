# Expat-GÉANT Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter Configuration (required)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default LLM model to use (optional)
# Examples: anthropic/claude-haiku-4.5, openai/gpt-4, mistral/mixtral-8x7b
# See available models at: https://openrouter.ai/models
DEFAULT_LLM_MODEL=anthropic/claude-haiku-4.5

# OpenRouter Base URL (optional, uses default if not set)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Database Configuration (for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/expat_geant

# Session Configuration
# SESSION_TTL_HOURS=48

# Vector Database Configuration
# CHROMA_PERSIST_DIRECTORY=./chroma_data
