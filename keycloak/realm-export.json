{
  "realm": "expats",
  "enabled": true,
  "displayName": "Expats",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "external",
  "loginTheme": "keycloak",
  "defaultSignatureAlgorithm": "RS256",
  "clients": [
    {
      "clientId": "cue-api",
      "name": "M-Autofill",
      "description": "Expats M-Autofill answer suggestion service",
      "enabled": true,
      "publicClient": false,
      "secret": "change-me",
      "redirectUris": [
        "http://localhost:8001/auth/callback",
        "http://localhost:8002/auth/callback",
        "http://localhost:8003/auth/callback",
        "http://localhost:8004/auth/callback"
      ],
      "webOrigins": [
        "http://localhost:8001",
        "http://localhost:8002",
        "http://localhost:8003",
        "http://localhost:8004",
        "http://keycloak:8001",
        "http://keycloak:8002"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {"post.logout.redirect.uris": "http://localhost:8002##http://localhost:8004"},
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email",
        "basic"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "respondent",
        "description": "Survey respondent role"
      }
    ]
  },
  "defaultRoles": [
    "respondent"
  ],
  "users": []
}
