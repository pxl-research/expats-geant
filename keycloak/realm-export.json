{
  "realm": "expats",
  "enabled": true,
  "displayName": "Expats",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "passwordPolicy": "length(12) and notUsername and notEmail",
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyInitialCounter": 0,
  "loginTheme": "keycloak",
  "defaultSignatureAlgorithm": "RS256",
  "clients": [
    {
      "clientId": "cue-api",
      "name": "Cue",
      "description": "Expats Cue answer suggestion service",
      "enabled": true,
      "publicClient": false,
      "secret": "change-me",
      "redirectUris": [
        "http://localhost:8002/auth/callback",
        "http://localhost:8004/auth/callback"
      ],
      "webOrigins": [
        "http://localhost:8001",
        "http://localhost:8002",
        "http://localhost:8003",
        "http://localhost:8004"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {"post.logout.redirect.uris": "http://localhost:8002##http://localhost:8004"},
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email",
        "basic"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "respondent",
        "description": "Survey respondent role"
      }
    ]
  },
  "defaultRoles": [
    "respondent"
  ],
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10
    }
  ],
  "users": []
}
